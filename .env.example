# Render Environment Variables Guide
# Copy these keys and values into the Render Dashboard's Environment Variables section

NODE_ENV=production
JWT_SECRET=              # Click 'Generate' or enter a random string
SUPABASE_URL=           # Copy from your Supabase Project Settings
SUPABASE_SERVICE_ROLE_KEY= # Copy from your Supabase Project Settings

# Optional: For Google Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_URL=                 # Example: https://veiculopro.onrender.com
PORT=10000               # Value for Render's default port

# Frontend specific (built into the app)
GEMINI_API_KEY=          # If needed for AI features
